# author: Claude (claude-opus-4-7)
# created: 2026-05-20
# modified:
#   - 2026-05-20: Claude (claude-opus-4-7) — removed .vscode/ blanket ignore; project-level VS Code settings should be versioned (Rule 6). Only per-device overrides are ignored.
#   - 2026-06-26: Claude (claude-opus-4-8) — ignore *.upa/*.upb (LaTeX aux sidecars) and **/target/ (cargo build artifacts under src/).

# === LaTeX build artifacts ===
# Aux / log / toc family
*.aux
*.log
*.toc
*.lof
*.lot
*.out
*.loe

# BibTeX / biblatex
*.bbl
*.blg
*.bcf
*.run.xml

# latexmk / synctex
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)

# DVI / PS intermediates
*.dvi
*.ps

# Beamer
*.nav
*.snm
*.vrb

# makeindex
*.idx
*.ind
*.ilg

# glossaries
*.glo
*.gls
*.glg
*.acn
*.acr

# epstopdf / graphicx auto-conversions
*-converted-to.pdf

# todonotes / other listings sidecars
*.tdo
*.lol

# misc aux sidecars (under-tilde etc.)
*.upa
*.upb

# Final compiled output (regenerable from source)
main.pdf

# === Editor / OS ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/

# VS Code: project-level settings are versioned (.vscode/settings.json, .vscode/extensions.json).
# Only per-device overrides are ignored.
.vscode/settings.local.json
.vscode/*.log

# === Claude Code (per-device local settings) ===
# Note: .claude/memory/ is versioned (see CLAUDE.md Rule 6). Only local-overrides are ignored.
.claude/settings.local.json

# === Rust / cargo (code snippets under src/) ===
**/target/
